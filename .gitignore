# Spring Design Agent – .gitignore
# ─────────────────────────────────────────────────────────────────

# Environment
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
*.xml

# E2E generated artifacts
_e2e_*.dxf
_e2e_*.pdf

# Type checking
.mypy_cache/

# Linting
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Database
*.db
*.sqlite3
*.sqlite
*.sqlite-shm
*.sqlite-wal

# ChromaDB local storage
chroma_data/

# LangGraph checkpointer local storage (Phase 3 — multi-turn conversation)
data/checkpoints/

# Alembic
alembic/versions/*.py
!alembic/versions/.gitkeep

_e2e_test.*

