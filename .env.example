# Spring Design Agent – Environment Configuration
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Application ────────────────────────────────────────────────────────────
APP_NAME="Spring Design Agent API"
DEBUG=false
LOG_LEVEL=INFO

# ── LLM Orchestration ──────────────────────────────────────────────────────
# Comma-separated priority list. First available provider wins.
# Ollama local no requiere API key — recomendado como default.
# Si un proveedor se agota (quota/rate-limit), rota automáticamente.
LLM_PRIORITY_ORDER=ollama,gemini,grok,openai,anthropic
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Google Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── xAI Grok ──────────────────────────────────────────────────────────────
GROK_API_KEY=your-grok-api-key-here
GROK_MODEL=grok-3-mini
GROK_BASE_URL=https://api.x.ai/v1

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic Claude ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── Ollama (local fallback) ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://postgres:password@localhost:5432/springs_db

# ── ChromaDB (normative standards vector store) ────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_STANDARDS=spring_standards

# ── Redis (optional alternative) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# ── Workflow ──────────────────────────────────────────────────────────────
MAX_DESIGN_ITERATIONS=5
